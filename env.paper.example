# =============================================================================
# 한국투자 모의투자(paper) 로컬 실행용 환경 변수 예시
# -----------------------------------------------------------------------------
# 1) 이 파일을 복사해 `.env.paper` 를 만든 뒤 값을 채웁니다.
# 2) 검토 후 동일 내용을 `.env` 로 복사합니다. (백엔드는 `.env` 만 자동 로드)
# 3) `.env` / `.env.paper` 는 git 에 커밋하지 마세요.
# 4) 오늘 바로 실행 순서: Docs/today_run_checklist.md
# =============================================================================

# JWT·브로커 암호화용 (운영 시 반드시 긴 임의 문자열로 변경)
APP_SECRET_KEY=please-change-me-to-a-long-random-string-min-16

# --- 계정·브로커·SQLite 저장 경로 (기본: ./backend_data 아래로 통일) ---
# 로컬/Render Persistent Disk 등 한 디렉터리로 고정하는 것을 권장합니다.
# BACKEND_DATA_DIR=backend_data
# (선택) 개별 파일을 분리할 때만 지정 — 미지정 시 BACKEND_DATA_DIR 기준
# AUTH_USERS_PATH=
# AUTH_REVOKED_TOKENS_PATH=
# BROKER_ACCOUNTS_DB_PATH=
# DATABASE_URL=sqlite:///./trading.db

# --- 실거래: 기본 전부 OFF (실주문은 다중 플래그 없이 불가) ---
TRADING_MODE=paper
LIVE_TRADING=false
LIVE_TRADING_ENABLED=false
LIVE_TRADING_CONFIRM=false
LIVE_TRADING_EXTRA_CONFIRM=false

# --- 한국투자 Open API (모의투자 앱키) ---
KIS_APP_KEY=
KIS_APP_SECRET=

# 모의: openapivts / 실전: openapi (TRADING_MODE=paper 이면 모의 URL 이 사용됨)
KIS_MOCK_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# 모의계좌 CANO(보통 8자리) + 계좌상품코드(예: 01)
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01

# --- Paper / KIS 모의 API 부하 완화 (EGW00201 초당한도) ---
# 동일 호스트 요청 최소 간격(ms). Render·모의에서 250~400 권장.
# KIS_MIN_REQUEST_INTERVAL_MS=300
# KIS_RATE_LIMIT_MAX_RETRIES=8
# KIS_RATE_LIMIT_BACKOFF_BASE_SEC=0.55
# KIS_RATE_LIMIT_BACKOFF_CAP_SEC=32
# Paper 세션 틱 간격(초) — 기본 600. 백엔드 Paper 루프는 이 값을 사용합니다.
# PAPER_TRADING_INTERVAL_SEC=600
# 종목 수·룩백·캐시·스냅샷/동기화 간격(초보자·Render 권장 묶음)
# PAPER_TRADING_SYMBOLS=005930,000660
# PAPER_KIS_CHART_LOOKBACK_DAYS=60
# 짧은 별칭 또는 PAPER_KIS_* 이름 모두 동일 필드로 읽힘
# PAPER_UNIVERSE_CACHE_TTL_SEC=300
# PAPER_KOSPI_CACHE_TTL_SEC=300
# PAPER_POSITIONS_REFRESH_INTERVAL_SEC=900
# PAPER_PORTFOLIO_SYNC_INTERVAL_SEC=1800
# 전역 런타임 엔진 루프(초) — Paper와 별개이나 배포에서 같이 600으로 맞추는 경우 많음
# RUNTIME_LOOP_INTERVAL_SEC=600
# PAPER_SMOKE_MODE=false

# --- Paper 멀티 전략(스윙 일봉 + 인트라데이 스캘프) — Render 등 서버 .env 에 복사 ---
# 켜려면: Paper 세션 전략 ID를 scalp_momentum_v2 또는 v3(v1) 로 선택 + 아래 true
# PAPER_MULTI_STRATEGY_MODE=true
# PAPER_INTRADAY_ENABLED=true
# PAPER_MULTI_SWING_STRATEGY_ID=swing_relaxed_v1
# PAPER_SWING_CAPITAL_PCT=60
# PAPER_INTRADAY_CAPITAL_PCT=40
# PAPER_MAX_CAPITAL_PER_POSITION_PCT=8
# PAPER_RISK_PER_TRADE_PCT=0.45
# PAPER_MULTI_ROUTER_PREFER_SCALP_ON_OVERLAP=true
# (선택) 멀티 없이도 스캘프만 리스크 기반 수량
# PAPER_INTRADAY_RISK_BASED_QUANTITY=false

# (선택) 앱 코어 Settings — 주문 엔진·스크리너와 동일 계좌 권장
# ACCOUNT_NUMBER=
# ACCOUNT_PRODUCT_CODE=

# --- 성과·FIFO: 체결에 수수료/세금 컬럼이 없을 때 적용 비율(소수, 0.0015 = 0.15%) ---
# KIS_BUY_FEE_RATE=0.00015
# KIS_SELL_FEE_RATE=0.00015
# KRX_SELL_TAX_RATE=0.0015

# --- 실거래 잠금 해제 전 모의(paper) 자동 검증 (LIVE_UNLOCK_*) ---
# LIVE_UNLOCK_ENABLED=true
# LIVE_UNLOCK_BYPASS=false
# LIVE_UNLOCK_LOOKBACK_DAYS=30
# LIVE_UNLOCK_MIN_PNL_SAMPLES=10
# LIVE_UNLOCK_MIN_PERIOD_RETURN_PCT=0
# LIVE_UNLOCK_MAX_MDD_PCT=15
# LIVE_UNLOCK_MAX_CONSECUTIVE_LOSS_DAYS=5
# LIVE_UNLOCK_MAX_ORDER_ISSUE_RATE=0.05
# LIVE_UNLOCK_MAX_SYNC_FAILURE_STREAK=0
