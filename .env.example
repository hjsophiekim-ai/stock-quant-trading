# Korean Investment & Securities Open API app key (keep secret, do not commit real value)
KIS_APP_KEY=

# Korean Investment & Securities Open API app secret (keep secret, do not commit real value)
KIS_APP_SECRET=

# KIS account number (digits only, no hyphen)
KIS_ACCOUNT_NO=

# KIS account product code (usually 2 digits)
KIS_ACCOUNT_PRODUCT_CODE=

# KIS API base URL for request routing (set to mock or live endpoint by environment)
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# Trading mode: paper | live (default is paper for safety)
TRADING_MODE=paper

# Live order execution switch: must be true to allow live orders
LIVE_TRADING=false

# Extra confirmation flag for live orders (must also be true)
LIVE_TRADING_CONFIRM=false

# Print dry-run safety log before each live order request
LIVE_ORDER_DRY_RUN_LOG=true

# Database connection string (example uses local SQLite)
DATABASE_URL=sqlite:///./trading.db

# Redis connection string for cache/queue (example local default)
REDIS_URL=redis://localhost:6379/0

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
